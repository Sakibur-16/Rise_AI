# ============================================================
# Rise AI Microservice — Master AI Provider Configuration
# ============================================================
# Copy this file to ".env" and fill in the key for your chosen provider.
# Never commit the real ".env" — it is already in .gitignore.
#
# STEP 1 — pick a provider:
AI_PROVIDER=anthropic
#   Supported values: anthropic | openai | google | groq | mistral | together
#
# STEP 2 — fill in the key(s) for that provider (others can stay blank).
# STEP 3 — set the model name for that provider (see options below).
# ============================================================


# ──────────────────────────────────────────────
# ANTHROPIC  (Claude)
# Docs: https://docs.anthropic.com
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-ME
# Model options: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-8
ANTHROPIC_MODEL=claude-haiku-4-5-20251001


# ──────────────────────────────────────────────
# OPENAI  (GPT)
# Docs: https://platform.openai.com/docs
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE-ME
# Model options: gpt-4o-mini | gpt-4o | gpt-4-turbo | o1-mini | o3-mini
OPENAI_MODEL=gpt-4o-mini
# Optional: override base URL for Azure OpenAI or compatible endpoints
# OPENAI_BASE_URL=   # uncomment + set only for Azure / custom endpoints


# ──────────────────────────────────────────────
# GOOGLE GEMINI
# Docs: https://ai.google.dev/docs
# ──────────────────────────────────────────────
GOOGLE_API_KEY=REPLACE-ME
# Model options: gemini-2.0-flash | gemini-2.0-flash-lite | gemini-1.5-pro
GOOGLE_MODEL=gemini-2.0-flash


# ──────────────────────────────────────────────
# GROQ  (ultra-fast inference, OpenAI-compatible)
# Docs: https://console.groq.com/docs
# ──────────────────────────────────────────────
GROQ_API_KEY=gsk_REPLACE-ME
# Model options: llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile


# ──────────────────────────────────────────────
# MISTRAL AI
# Docs: https://docs.mistral.ai
# ──────────────────────────────────────────────
MISTRAL_API_KEY=REPLACE-ME
# Model options: mistral-small-latest | mistral-medium-latest | mistral-large-latest
MISTRAL_MODEL=mistral-small-latest


# ──────────────────────────────────────────────
# TOGETHER AI  (open-source models, OpenAI-compatible)
# Docs: https://docs.together.ai
# ──────────────────────────────────────────────
TOGETHER_API_KEY=REPLACE-ME
# Model options: meta-llama/Llama-3.3-70B-Instruct-Turbo | mistralai/Mixtral-8x7B-Instruct-v0.1
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo


# ──────────────────────────────────────────────
# SHARED SETTINGS  (apply to all providers)
# ──────────────────────────────────────────────
# How many times to retry a failed API call (rate limits / transient errors).
AI_MAX_RETRIES=3
